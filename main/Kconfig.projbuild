menu "WiFi Configuration"

config WIFI_SSID
    string "WiFi SSID"
    default ""

config WIFI_PASSWORD
    string "WiFi Password"
    default ""

endmenu

menu "Location Configuration"

config LOCATION_LATITUDE
    string "Latitude (decimal degrees)"
    default "37.8012"

config LOCATION_LONGITUDE
    string "Longitude (decimal degrees)"
    default "-122.2695"

endmenu

menu "Time Configuration"

config TIMEZONE
    string "POSIX Timezone string"
    default "PST8PDT,M3.2.0,M11.1.0"
    help
        POSIX timezone string used by SNTP.
        Examples:
          Pacific: PST8PDT,M3.2.0,M11.1.0
          Eastern: EST5EDT,M3.2.0,M11.1.0
          UTC:      UTC0

endmenu

menu "External I2C Bus"

    choice EXT_I2C_BUS
        prompt "External I2C bus pins"
        default EXT_I2C_BUS_PORT_A

        config EXT_I2C_BUS_PORT_A
            bool "Use Port A pins"

        config EXT_I2C_BUS_PORT_B
            bool "Use Port B pins"

        config EXT_I2C_BUS_PORT_C
            bool "Use Port C pins"
    endchoice

endmenu

menu "Finnhub Stock Ticker Configuration"

    config FINNHUB_API_KEY
        string "Finnhub API Key"
        default ""
        help
            Your Finnhub API key. Get a free key at https://finnhub.io.
            Example: "d1a2b3c4d5e6f7g8h9i0"

    config FINNHUB_POLL_INTERVAL_SEC
        int "Poll interval (seconds)"
        default 60
        range 15 3600
        help
            How often to fetch updated stock quotes from Finnhub.
            Minimum 15 seconds. Free tier allows 60 calls/minute.

    menu "Stock Symbols"

        config FINNHUB_SYMBOL_1
            string "Symbol 1"
            default "DIA"
            help
                First stock symbol to display (e.g. AAPL, TSLA, MSFT).

        config FINNHUB_SYMBOL_2
            string "Symbol 2"
            default "SPY"
            help
                Second stock symbol. Leave blank to disable.

        config FINNHUB_SYMBOL_3
            string "Symbol 3"
            default "QQQ"
            help
                Third stock symbol. Leave blank to disable.

        config FINNHUB_SYMBOL_4
            string "Symbol 4"
            default ""
            help
                Fourth stock symbol. Leave blank to disable.

        config FINNHUB_SYMBOL_5
            string "Symbol 5"
            default ""
            help
                Fifth stock symbol. Leave blank to disable.

        config FINNHUB_SYMBOL_6
            string "Symbol 6"
            default ""
            help
                Sixth stock symbol. Leave blank to disable.

    endmenu  # Stock Symbols

endmenu  # Finnhub Stock Ticker Configuration
