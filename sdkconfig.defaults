# ── WiFi ──────────────────────────────────────────────────────────────────────
CONFIG_WIFI_SSID=""
CONFIG_WIFI_PASSWORD=""

# ── Location (decimal degrees) ────────────────────────────────────────────────
CONFIG_LOCATION_LATITUDE="37.8012"
CONFIG_LOCATION_LONGITUDE="-122.2695"

# ── Timezone (POSIX string) ───────────────────────────────────────────────────
CONFIG_TIMEZONE="PST8PDT,M3.2.0,M11.1.0"

# ── Finnhub ───────────────────────────────────────────────────────────────────
CONFIG_FINNHUB_API_KEY=""
CONFIG_FINNHUB_POLL_INTERVAL_SEC=60
CONFIG_FINNHUB_SYMBOL_1="DIA"
CONFIG_FINNHUB_SYMBOL_2="SPY"
CONFIG_FINNHUB_SYMBOL_3="QQQ"
CONFIG_FINNHUB_SYMBOL_4=""
CONFIG_FINNHUB_SYMBOL_5=""
CONFIG_FINNHUB_SYMBOL_6=""

# ── mbedTLS – dynamic I/O buffers reduce per-connection heap from ~20 KB to
#    only what is needed during active data transfer, allowing 2+ concurrent
#    TLS sessions within the ESP32-S3's internal SRAM budget.
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=16384
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=4096

# ── (Optional) Enable PSRAM to increase heap and allow more HTTP workers ──────
# CONFIG_SPIRAM=y
# CONFIG_ESP32S3_SPIRAM_SUPPORT=y
# CONFIG_SPIRAM_MODE_OCT=y
# CONFIG_SPIRAM_SPEED_80M=y
# CONFIG_SPIRAM_USE_MALLOC=y
